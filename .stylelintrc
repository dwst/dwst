{
  "plugins": [
    "stylelint-no-unsupported-browser-features"
  ],
  "rules": {
    "max-nesting-depth": 1,
    "declaration-block-single-line-max-declarations": 1,
    "number-max-precision": 1,
    "selector-max-attribute": 0,
    "selector-max-class": 2,
    "selector-max-combinators": 1,
    "selector-max-compound-selectors": 2,
    "selector-max-id": 0,
    "selector-max-specificity": "0,4,0",
    "selector-max-type": 0,
    "selector-max-universal": 0,

    "time-min-milliseconds": 100,

    "color-named": "never",
    "font-family-name-quotes": "always-where-recommended",
    "font-weight-notation": "named-where-possible",
    "function-url-quotes": "always",
    "selector-pseudo-element-colon-notation": "single",
    "selector-attribute-quotes": "always",

    "custom-property-pattern": "^dwst-[-a-z0-9]+$",
    "selector-class-pattern": "^dwst-[-a-z0-9_]+$",
    "selector-id-pattern": "^$",
    "selector-nested-pattern": "^$",
    "custom-media-pattern": "^$",

    "property-disallowed-list": [],
    "comment-word-disallowed-list": [],
    "declaration-property-unit-disallowed-list": {},
    "declaration-property-value-disallowed-list": {},

    "function-url-scheme-allowed-list": [],
    "selector-attribute-operator-allowed-list": ["="],
    "unit-allowed-list": ["%", "ch", "em", "pt", "px", "vh", "vw"],
    "at-rule-allowed-list": ["media", "import"],
    "media-feature-name-allowed-list": ["min-width"],
    "selector-pseudo-class-allowed-list": [
      "active",
      "after",
      "before",
      "hover",
      "nth-child",
      "host",
      "root",
      "window-inactive"
    ],
    "function-allowed-list": [
      "linear-gradient",
      "translateX",
      "calc",
      "rgba",
      "url",
      "var"
    ],

    "color-no-invalid-hex": true,
    "font-family-no-duplicate-names": true,
    "function-calc-no-unspaced-operator": true,
    "function-linear-gradient-no-nonstandard-direction": true,
    "string-no-newline": true,
    "unit-no-unknown": true,
    "shorthand-property-no-redundant-values": true,
    "property-no-unknown": true,
    "keyframe-declaration-no-important": true,
    "declaration-block-no-duplicate-properties": true,
    "declaration-block-no-redundant-longhand-properties": [
      true,
      { "ignoreShorthands": ["inset"] }
    ],
    "declaration-block-no-shorthand-property-overrides": true,
    "block-no-empty": true,
    "selector-pseudo-class-no-unknown": true,
    "selector-pseudo-element-no-unknown": true,
    "selector-type-no-unknown": true,
    "media-feature-name-no-unknown": true,
    "at-rule-no-unknown": true,
    "comment-no-empty": true,
    "no-descending-specificity": null,
    "no-duplicate-selectors": null,
    "no-empty-source": true,
    "no-invalid-double-slash-comments": true,
    "no-unknown-animations": true,
    "color-no-hex": null,
    "function-url-no-scheme-relative": true,
    "value-no-vendor-prefix": true,
    "property-no-vendor-prefix": true,
    "declaration-no-important": true,
    "selector-no-qualifying-type": null,
    "selector-no-vendor-prefix": true,
    "media-feature-name-no-vendor-prefix": true,
    "at-rule-no-vendor-prefix": true,
    "length-zero-no-unit": true,

    "plugin/no-unsupported-browser-features": [
      true,
      {
        "ignore": ["css-masks", "css-hyphens", "multicolumn"]
      }
    ]
  }
}

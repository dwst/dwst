{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "dwst/scripts/dwst.js",
    "dwst/scripts/service_worker.js",
    "test/test.js",
    "gulpfile.babel.js"
  ],
  "project": [
    "dwst/scripts/**/*.js",
    "test/**/*.js",
    "dwst/test/**/*.js"
  ],
  "ignoreDependencies": [
    "@babel/register",
    "babel-loader",
    "eslint-plugin-chai-friendly",
    "eslint-plugin-import"
  ],
  "rules": {
    "duplicates": "off"
  },
  "treatConfigHintsAsErrors": true
}
